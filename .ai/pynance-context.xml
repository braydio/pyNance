    description: |
      Create a symbol map for the current repository and save it to a file.
outputs:
  - name: symbols
    description: "JSON mapping of file paths to discovered symbols."
agent_guidance: |
  Run this after significant code changes to refresh context used by
  maintenance agents.
dependencies:
  - tree-sitter
