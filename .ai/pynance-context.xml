import { computed, onMounted, ref } from 'vue'
import UiButton from '@/components/ui/Button.vue'
import { usePlanning } from '@/composables/usePlanning'
import {
  selectActiveScenario,
  selectAllocatedCents,
  selectRemainingCents,
