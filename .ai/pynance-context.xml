  message: { type: String, required: true },
})

const emit = defineEmits(['close'])

const visible = ref(true)

watch(
  () => props.message,
  () => {
    visible.value = true
    setTimeout(() => {
      visible.value = false
      emit('close')
    }, 3000)
  },
)

function close() {
  visible.value = false
  emit('close')
}
