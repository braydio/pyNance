.daily-net-chart__hover-dot {
  width: 0.4rem;
  height: 0.4rem;
  border-radius: 999px;
  background: var(--color-accent-cyan);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-accent-cyan) 25%, transparent);
}

.daily-net-chart__hover-label {
  color: var(--color-text-light);
}

