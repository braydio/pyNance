import { ref } from 'vue'
import { BarChart, Bar, XAxis, YAxis, Tooltip } from 'recharts'
import Modal from '@/components/ui/Modal.vue'

const netIncomeData = [
  { date: '2025-05-01', net: 120 },
  { date: '2025-05-02', net: -40 },
  { date: '2025-05-03', net: 75 },
]

